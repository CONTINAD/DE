# --------------------------------------------------------------------
# $DELL — config template. Copy to .env (local) or paste into Railway → Variables.
#
# Every CYCLE_INTERVAL_SECONDS the bot:
#   1. Claims pump.fun creator fees (SOL) on the TREASURY (dev) wallet
#   2. Buys real tokenized DELL (Backed/xStocks "DELLx") on Jupiter with the
#      spendable share of the claim — one stock, all Dell, every cycle
#   3. Snapshots holders and keeps wallets holding >= MIN_HOLDER_BALANCE
#   4. Airdrops the DELL to EVERY qualified holder, PROPORTIONAL to how much
#      $DELL they hold
#
# Payout routing: each batch of holders is paid through a FRESH, bot-generated
# relay wallet. The relay's temporary stock account is opened and closed inside
# the SAME atomic transaction (treasury -> relay -> holders -> relay closes), so
# its rent round-trips and no single wallet is the on-chain parent of all holders.
#
# Safety: the bot can only ever SPEND SOL it has provably CLAIMED (the
# claimPoolLamports ledger, reconciled to the real measured balance delta each
# cycle). The dev's principal is never touched.
# --------------------------------------------------------------------

# --- Solana RPC (REQUIRED) ---
# Use a PAID RPC (Helius / QuickNode / Triton). Free RPCs disable
# getProgramAccounts, which is required to snapshot holders.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Wallets (REQUIRED) ---
# The ONLY key you provide. The TREASURY (dev) wallet OWNS the pump.fun $DELL
# token, receives the creator fees, buys the DELL, and funds the airdrop. Every
# relay wallet is generated by the bot at runtime — you never supply a hot key.
# Paste your NEW dev wallet's base58 private key here:
CREATOR_WALLET_PRIVATE_KEY=PASTE_DEV_WALLET_PRIVATE_KEY

# Optional marketing slice: keep MARKETING_PERCENT of each claim back on the
# treasury (held, never auto-sent — withdraw manually). 0 = 100% buys DELL.
# MARKETING_WALLET=
MARKETING_PERCENT=0

# --- Your pump.fun coin ($DELL) ---
# auto = watch the treasury wallet and adopt the next pump.fun token it launches.
# Once $DELL is live you can hardcode its mint here instead of "auto".
XSTOCKS_MINT=auto
MINT_WATCH_POLL_SECONDS=20

# --- PumpPortal (optional) ---
# Lightning API key for server-side claim signing. Blank = local signing.
PUMPPORTAL_API_KEY=

# --- Jupiter (the SOL -> DELL swap) ---
JUPITER_BASE_URL=https://lite-api.jup.ag
SWAP_SLIPPAGE_BPS=150              # 1.5%. DELLx liquidity is thin — raise if buys fail.

# --- The mechanic ---
CYCLE_INTERVAL_SECONDS=300         # 300 = 5 minutes between cycles
MIN_HOLDER_BALANCE=500000          # must hold >= this many $DELL to qualify
RESERVE_PERCENT=10                 # keep 10% of every claim back as SOL buffer
MIN_DISPENSE_SOL=0.02              # skip the cycle if the spendable pool < this
MAX_RECIPIENTS_PER_CYCLE=600       # safety cap on recipients per cycle (largest first)
PAYOUT_BATCH_SIZE=6                # holders per tx/relay (max 10 with ATA creation)
PRIORITY_FEE=0.0005                # base SOL priority fee (escalates on retry)
ATA_RENT_ESTIMATE_SOL=0.0023       # pre-swap reserve per NEW holder stock account

# Rotation is DELL-only by default. Leave this unset. (Advanced: override with
# comma-separated symbols that exist in src/rotation.ts, e.g. STOCK_ROTATION=DELLx)
# STOCK_ROTATION=DELLx

# --- State persistence (so lifetime totals NEVER reset across redeploys) ---
# DATABASE_URL: a Postgres connection string. When set, the FULL dashboard state
# (total DELL shipped, SOL spent, payouts, cycles, per-holder history) is
# snapshotted to Postgres and reloaded on boot — nothing resets on redeploy.
# On Railway: add a Postgres plugin, then set:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# If unset, the app uses a local JSON file (data/state.json) which is EPHEMERAL
# on Railway — totals WOULD reset on redeploy. Use Postgres in production.
# DATABASE_URL=
# STATE_DIR=/data

# --- Dashboard ---
PORT=3000
LOG_LEVEL=info
